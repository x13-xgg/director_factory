# ═══════════════════════════════════════════════════
# 全自动导演工厂 — 生产环境变量模板
# 复制为 .env 并填写实际值
# ═══════════════════════════════════════════════════

# 运行模式: production | staging | development
DIRECTOR_MODE=development

# Mock 开关 — production 模式默认关闭
MOCK_ALL=true

# ── LLM API ──────────────────────────────────────
LLM_PROVIDER=auto
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_DEFAULT_MODEL=deepseek-v4-pro
LLM_FALLBACK_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF=2.0

# ── 图像生成 ─────────────────────────────────────
IMG_PROVIDER=mock
COMFYUI_URL=http://comfyui:8188
COMFYUI_WS_URL=ws://comfyui:8188
SDXL_MODEL=sdxl_v3
LORA_DIR=assets/loras
IMG_STEPS=30
IMG_CFG=7.5
IMG_WIDTH=1024
IMG_HEIGHT=576
IMG_BATCH_SIZE=1

# ── TTS ──────────────────────────────────────────
# edge_tts (免费零配置) | chattts (本地高质量中文) | bark (本地英文) | mock
TTS_PROVIDER=mock
BARK_URL=http://bark:5000
CHATTS_MODEL_PATH=assets/models/chattts
TTS_SAMPLE_RATE=24000
TTS_LANGUAGE=zh

# ── 消息总线 ─────────────────────────────────────
# memory | redis (fakeredis 自动兜底, 无需真实 Redis)
MSG_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAXLEN=10000
MSG_TIMEOUT=60.0
MSG_DEAD_LETTER=false

# ── 数据库 ───────────────────────────────────────
DATABASE_BACKEND=memory
DATABASE_URL=postgresql://director:director@postgres:5432/director_factory
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_VECTOR_DIM=512
CHECKPOINT_DIR=outputs/checkpoints

# ── GPU 资源 ─────────────────────────────────────
GPU_VRAM_GB=24.0
GPU_VRAM_PER_SHOT=2.5
MAX_CONCURRENT_SHOTS=8
MAX_RETRIES=3
QUALITY_THRESHOLD=0.85

# ── 日志与监控 ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
METRICS_ENABLED=false
METRICS_PORT=9090
TRACE_ENABLED=true
SENTRY_DSN=

# ── 项目 ─────────────────────────────────────────
PROJECT_NAME=director_factory
OUTPUT_DIR=outputs
